{
  "version": "2.0.0",
  "tasks": [{
    "label": "build",
    "type": "shell",
    "command": "C:/msys64/mingw64/bin/g++.exe",
    "args": [
      "code.cpp",
      "-o", "code.exe",
      "-lglew32", "-lglfw3", "-lopengl32", "-lgdi32", "-lglew32", "-lglu32"
    ],
    "options": {
      "cwd": "${workspaceFolder}"
    },
    "group": { "kind": "build", "isDefault": true }
  }]
}

